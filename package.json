{
  "name": "ally",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --skipLibCheck --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node app.js",
    "dev": "slackcli run",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "test": "node --test",
    "seed:jira": "node scripts/seed-jira.js",
    "seed:slack": "node scripts/seed-slack.js"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@slack/cli-hooks": "^1.3.2",
    "typescript": "^6.0.3"
  }
}
